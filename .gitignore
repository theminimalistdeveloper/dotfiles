# =============================================================================
# Dotfiles .gitignore
# Stow-based dotfiles for macOS and Arch Linux.
# Anything generated, machine-specific, or sensitive should stay out of git.
# =============================================================================

# -----------------------------------------------------------------------------
# Operating system metadata
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
Icon\r

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Editor / IDE artifacts
# -----------------------------------------------------------------------------

# Vim / Neovim swap, backup, undo, session files
*.swp
*.swo
*.swn
*.swm
*.un~
*.bak
*.orig
*.rej
Session.vim
.netrwhist
tags
tags.lock
tags.temp

# -----------------------------------------------------------------------------
# Neovim (vim.pack runtime + downloaded assets)
# -----------------------------------------------------------------------------

# Auto-installed plugins / autoload (downloaded at runtime)
nvim/.config/nvim/plugins/**
nvim/.config/nvim/autoload/**
nvim/.config/nvim/pack/**
nvim/.config/nvim/site/pack/**

# Local-only Neovim state that may end up under the config dir
nvim/.config/nvim/shada/
nvim/.config/nvim/spell/
nvim/.config/nvim/swap/
nvim/.config/nvim/undo/
nvim/.config/nvim/view/
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/.luarc.json.local

# -----------------------------------------------------------------------------
# Shell (zsh) — history and machine-local overrides
# -----------------------------------------------------------------------------

# Zsh history / completion / compiled files
zsh/.zsh_history
zsh/.zsh_sessions/
zsh/.zcompdump*
zsh/.zcompcache/
zsh/.zlogin
zsh/.zlogout
*.zwc

# Local-only / per-host shell overrides (sourced by .zshrc but not tracked)
*.local
*.local.zsh
zsh/.zshrc.local
zsh/.zshenv.local
zsh/.zprofile.local

# Spaceship prompt cache
spaceship/.config/spaceship.zsh.zwc

# -----------------------------------------------------------------------------
# tmux
# -----------------------------------------------------------------------------

tmux/.tmux/plugins/
tmux/plugins/
tmux/resurrect/
.tmux.conf.local

# -----------------------------------------------------------------------------
# Wayland / X11 / window manager runtime state
# -----------------------------------------------------------------------------

# Locally-generated cache or per-host configs
sway/.config/sway/config.local
i3/.config/i3/config.local
waybar/.config/waybar/*.local

# -----------------------------------------------------------------------------
# Secrets / credentials — NEVER commit these
# -----------------------------------------------------------------------------

.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.gpg
secrets/
.secrets/
.netrc
.npmrc
.pypirc

# -----------------------------------------------------------------------------
# Language / tool ecosystems (in case of helper scripts or experiments)
# -----------------------------------------------------------------------------

# Node / JavaScript / TypeScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/
.npm/
*.tsbuildinfo

# Rust
target/
Cargo.lock.bak
**/*.rs.bk

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Lua / luarocks
.luarocks/
luac.out

# -----------------------------------------------------------------------------
# Logs, archives, and temp files
# -----------------------------------------------------------------------------

*.log
logs/
*.tmp
*.temp
*.cache
.cache/

# Compressed archives (rarely belong in a config repo)
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar

# -----------------------------------------------------------------------------
# setup.sh artifacts
# -----------------------------------------------------------------------------

# Backups created by setup.sh before symlinking
*.dotfiles-backup/
dotfiles-backup-*/
setup.log

# -----------------------------------------------------------------------------
# AI artifacts
# -----------------------------------------------------------------------------
opencode.json
.opencode

